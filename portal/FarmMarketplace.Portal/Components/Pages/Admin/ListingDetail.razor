@page "/admin/listings/{ListingId:guid}"
@attribute [Authorize(Roles = "ADMIN,SUPER_ADMIN")]
@inject PortalApiClient ApiClient

<MudText Typo="Typo.h4" Class="fm-page-title mb-4">Listing Detail</MudText>

@if (_detail is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4" Outlined="true">
                <MudText Typo="Typo.h6">@_detail.Title</MudText>
                <MudText Typo="Typo.body2" Class="mb-2">@_detail.Description</MudText>
                <MudStack Row="true" Spacing="2">
                    <StatusBadge Status="@_detail.StatusCode" />
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">Price: @_detail.Price</MudChip>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">Qty: @_detail.Quantity</MudChip>
                </MudStack>
                <MudDivider Class="my-3" />
                <MudText><b>Seller:</b> @_detail.SellerName (@_detail.SellerUserId)</MudText>
                <MudText><b>Region/District:</b> @_detail.RegionId / @_detail.DistrictId</MudText>
                <MudText><b>Views:</b> @_detail.ViewCount</MudText>
                <MudText><b>Enquiries:</b> @_detail.EnquiryCount</MudText>
            </MudPaper>

            <MudPaper Class="pa-4 mt-3" Outlined="true">
                <MudText Typo="Typo.h6" Class="mb-2">Moderation Actions</MudText>
                <MudStack Row="true" Spacing="1">
                    <MudButton Size="Size.Small" OnClick='@(() => Act("approve"))'>Approve</MudButton>
                    <MudButton Size="Size.Small" Color="Color.Error" OnClick='@(() => Act("reject"))'>Reject</MudButton>
                    <MudButton Size="Size.Small" Color="Color.Warning" OnClick='@(() => Act("suspend"))'>Suspend</MudButton>
                    <MudButton Size="Size.Small" Color="Color.Success" OnClick='@(() => Act("reactivate"))'>Reactivate</MudButton>
                    <MudButton Size="Size.Small" OnClick='@(() => Act("feature"))'>Feature</MudButton>
                    <MudButton Size="Size.Small" OnClick='@(() => Act("unfeature"))'>Unfeature</MudButton>
                </MudStack>
                <MudTextField @bind-Value="_note" Label="Moderation note" Lines="2" Class="mt-2" />
                <MudButton Variant="Variant.Outlined" Class="mt-2" OnClick="SaveNote">Add Note</MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Outlined="true">
                <MudText Typo="Typo.h6">Images</MudText>
                @foreach (var image in _detail.Images)
                {
                    <MudImage Src="@image.ImageUrl" Alt="listing image" Style="width:100%;" Class="mb-2" />
                }
            </MudPaper>

            <MudPaper Class="pa-4 mt-3" Outlined="true">
                <MudText Typo="Typo.h6">Status History</MudText>
                <MudTimeline>
                    @foreach (var item in _detail.StatusHistory)
                    {
                        <MudTimelineItem Color="Color.Info">
                            <ItemContent>
                                <MudText Typo="Typo.body2">@item.StatusCode</MudText>
                                <MudText Typo="Typo.caption">@item.ChangedAtUtc.ToLocalTime()</MudText>
                            </ItemContent>
                        </MudTimelineItem>
                    }
                </MudTimeline>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid ListingId { get; set; }

    private AdminListingDetailVm? _detail;
    private string _note = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _detail = await ApiClient.GetAdminListingAsync(ListingId, CancellationToken.None);
    }

    private async Task Act(string action)
    {
        await ApiClient.PatchAsync($"/api/admin/listings/{ListingId}/{action}", new { StatusCode = action.ToUpperInvariant(), Reason = _note }, CancellationToken.None);
        _detail = await ApiClient.GetAdminListingAsync(ListingId, CancellationToken.None);
    }

    private async Task SaveNote()
    {
        if (string.IsNullOrWhiteSpace(_note))
        {
            return;
        }

        await ApiClient.PostAsync($"/api/admin/listings/{ListingId}/notes", new { Note = _note }, CancellationToken.None);
        _note = string.Empty;
    }
}
