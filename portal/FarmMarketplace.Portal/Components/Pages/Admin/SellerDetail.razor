@page "/admin/sellers/{UserId:guid}"
@attribute [Authorize(Roles = "ADMIN,SUPER_ADMIN")]
@inject PortalApiClient ApiClient

<MudText Typo="Typo.h4" Class="fm-page-title mb-4">Seller Detail</MudText>

@if (_detail is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4" Outlined="true">
                <MudText Typo="Typo.h6">@_detail.FullName</MudText>
                <MudText Typo="Typo.body2">@_detail.Email</MudText>
                <MudText Typo="Typo.body2">@_detail.Phone</MudText>
                <MudDivider Class="my-3" />
                <MudText><b>Business:</b> @_detail.BusinessName</MudText>
                <MudText><b>Description:</b> @_detail.Description</MudText>
                <MudText><b>Region/District:</b> @_detail.RegionId / @_detail.DistrictId</MudText>
                <MudText><b>Contact Mode:</b> @_detail.ContactMode</MudText>
                <MudText><b>Created:</b> @_detail.CreatedAtUtc.ToLocalTime()</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Outlined="true">
                <MudText Typo="Typo.h6" Class="mb-2">Status</MudText>
                <MudStack Spacing="1">
                    <StatusBadge Status="@(_detail.IsActive ? "ACTIVE" : "INACTIVE")" />
                    <StatusBadge Status="@(_detail.IsVerified ? "ACTIVE" : "PENDING")" />
                    <MudText Typo="Typo.body2">Total Listings: @_detail.TotalListings</MudText>
                    <MudText Typo="Typo.body2">Total Enquiries: @_detail.TotalEnquiries</MudText>
                </MudStack>
                <MudDivider Class="my-2" />
                <MudStack Spacing="1">
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick='@(() => Act("approve"))'>Approve</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" OnClick='@(() => Act("suspend"))'>Suspend</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success" OnClick='@(() => Act("reactivate"))'>Reactivate</MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid UserId { get; set; }

    private AdminSellerDetailVm? _detail;

    protected override async Task OnInitializedAsync()
    {
        _detail = await ApiClient.GetAdminSellerAsync(UserId, CancellationToken.None);
    }

    private async Task Act(string action)
    {
        await ApiClient.PatchAsync($"/api/admin/sellers/{UserId}/{action}", new { StatusCode = action.ToUpperInvariant(), Reason = "Portal action" }, CancellationToken.None);
        _detail = await ApiClient.GetAdminSellerAsync(UserId, CancellationToken.None);
    }
}
