@page "/seller/dashboard"
@attribute [Authorize(Roles = "SELLER")]
@inject PortalApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Seller Dashboard</PageTitle>

<MudText Typo="Typo.h4" Class="fm-page-title mb-4">Seller Dashboard</MudText>

@if (_summary is null)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else
{
    <div class="fm-grid-cards">
        <MetricCard Title="Active Listings" Value="@_summary.ActiveListings.ToString()" />
        <MetricCard Title="Received Enquiries" Value="@_summary.ReceivedEnquiries.ToString()" />
        <MetricCard Title="Active Plan" Value="@(_summary.ActivePlanName ?? "None")" />
        <MetricCard Title="Subscription Expiry" Value="@(_summary.SubscriptionEndDateUtc?.ToLocalTime().ToString("yyyy-MM-dd") ?? "N/A")" />
    </div>

    <MudStack Row="true" Spacing="2" Class="mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick='@(() => Navigation.NavigateTo("/seller/listings/new", true))'>Add Listing</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick='@(() => Navigation.NavigateTo("/seller/listings", true))'>View Listings</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick='@(() => Navigation.NavigateTo("/seller/profile", true))'>Edit Profile</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick='@(() => Navigation.NavigateTo("/seller/subscription", true))'>View Subscription</MudButton>
    </MudStack>
}

@code {
    private SellerDashboardSummaryVm? _summary;

    protected override async Task OnInitializedAsync()
    {
        _summary = await ApiClient.GetSellerDashboardSummaryAsync(CancellationToken.None);
    }
}
