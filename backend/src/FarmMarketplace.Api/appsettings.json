{
  "ConnectionStrings": {
    "MarketplaceDb": "Host=localhost;Port=5432;Database=farm_marketplace;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "FarmMarketplace",
    "Audience": "FarmMarketplaceClients",
    "Key": "CHANGE_THIS_IN_ENV_OR_USER_SECRETS",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
